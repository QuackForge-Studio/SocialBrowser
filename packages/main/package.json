{
    "name":  "@social-browser/main",
    "version":  "0.2.1",
    "private":  true,
    "main":  "dist/index.js",
    "scripts": {
        "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
        "lint": "eslint src/",
        "build": "node ../../scripts/build-main.mjs",
        "dev": "node scripts/dev.js",
        "package": "node ../../node_modules/electron-builder/cli.js --win --x64",
        "package:win": "node ../../node_modules/electron-builder/cli.js --win --x64",
        "package:mac": "node ../../node_modules/electron-builder/cli.js --mac --x64 --arm64",
        "package:linux": "node ../../node_modules/electron-builder/cli.js --linux --x64",
        "rebuild": "@electron/rebuild -f -w better-sqlite3 -w sqlite-vec",
        "verify-addons": "node ../../scripts/verify-addons.js"
    },
    "dependencies": {
        "better-sqlite3": "12.11.1",
        "sqlite-vec": "0.1.9",
        "sqlite-vec-windows-x64": "0.1.9",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@electron/rebuild": "4.2.0",
        "@types/jsdom": "^28.0.3",
        "electron": "43.1.1",
        "electron-builder": "26.15.3",
        "esbuild": "^0.28.1",
        "jsdom": "^29.1.1",
        "typescript": "5.8.3",
        "vitest": "^4.1.10"
    },
    "build": {
        "appId": "com.social-browser.app",
        "productName": "Social Browser",
        "executableName": "social-browser",
        "directories": {
            "output": "../../dist"
        },
        "files": [
            "dist/**/*",
            "package.json"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.social-networking"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Network"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "asar": true,
        "asarUnpack": [
            "node_modules/better-sqlite3/**",
            "node_modules/sqlite-vec/**",
            "node_modules/sqlite-vec-windows-x64/**",
            "dist/worker/**"
        ]
    }
}
