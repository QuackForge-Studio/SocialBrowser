{
    "name": "social-browser",
    "version": "0.1.0",
    "description": "Electron desktop app for social media content management with AI-powered drafting",
    "main": "src/main.js",
    "scripts": {
        "dev": "electron .",
        "package": "electron-builder --win --x64",
        "typecheck": "tsc --noEmit",
        "lint": "echo 'lint placeholder â€” ESLint not configured yet'",
        "test": "node -e \"console.log('test placeholder â€” Vitest not configured yet')\"",
        "test:integration": "node -e \"console.log('integration test placeholder')\"",
        "test:e2e": "node -e \"console.log('E2E test placeholder')\"",
        "build": "echo 'build placeholder'",
        "rebuild": "@electron/rebuild -f -w better-sqlite3 -w sqlite-vec",
        "verify-addons": "node scripts/verify-addons.js"
    },
    "dependencies": {
        "better-sqlite3": "12.11.1",
        "sqlite-vec": "0.1.9",
        "sqlite-vec-windows-x64": "0.1.9"
    },
    "devDependencies": {
        "@electron/rebuild": "4.2.0",
        "electron": "43.1.1",
        "electron-builder": "26.15.3",
        "typescript": "5.8.3"
    },
    "build": {
        "appId": "com.social-browser.app",
        "productName": "Social Browser",
        "directories": {
            "output": "dist"
        },
        "files": [
            "src/**/*",
            "node_modules/**/*",
            "!node_modules/.cache"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": null,
            "uninstallerIcon": null,
            "installerHeaderIcon": null
        },
        "asar": true,
        "asarUnpack": [
            "node_modules/better-sqlite3/**",
            "node_modules/sqlite-vec/**"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "better-sqlite3",
            "electron",
            "electron-winstaller",
            "@electron/rebuild"
        ]
    }
}
