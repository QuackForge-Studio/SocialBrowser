{
    "name":  "social-browser",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Social Browser monorepo",
    "scripts":  {
                    "typecheck":  "tsc -b",
                    "lint":  "eslint . --ext .ts",
                    "dev":  "pnpm --filter @social-browser/main dev",
                    "build":  "node scripts/build-all.mjs",
                    "package":  "pnpm --filter @social-browser/main package",
                    "test":  "powershell -File scripts/run-tests.ps1",
                    "test:integration":  "vitest run --config vitest.integration.config.ts",
                    "test:e2e":  "pnpm --filter @social-browser/e2e test",
                    "rebuild":  "@electron/rebuild -f -w better-sqlite3 -w sqlite-vec",
                    "verify-addons":  "node scripts/verify-addons.js"
                },
    "devDependencies":  {
                            "@types/node":  "^22.0.0",
                            "@typescript-eslint/eslint-plugin":  "^7.18.0",
                            "@typescript-eslint/parser":  "^7.18.0",
                            "eslint":  "^8.57.0",
                            "eslint-config-prettier":  "^9.1.0",
                            "prettier":  "^3.3.0",
                            "typescript":  "5.8.3",
                            "vitest":  "4.1.10"
                        },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "better-sqlite3",
                                               "electron",
                                               "electron-winstaller",
                                               "@electron/rebuild"
                                           ]
             }
}
